# =====================================================
# StrategyVault — Single Environment Configuration
# =====================================================
# This is the ONLY .env file for the entire project.
# Backend, frontend, and all integrations read from here.
# Copy this to .env and fill in your actual values.
# =====================================================

# ── Database ──────────────────────────────────────────
DATABASE_URL=sqlite:///./strategyvault.db

# ── AI Model APIs ─────────────────────────────────────
# Required: Get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key

# Optional: For multi-model swarm consensus
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# ── Authentication ────────────────────────────────────
JWT_SECRET_KEY=change-this-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Redis Cache ───────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true

# ── Stripe (optional, for payments) ──────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── CORS (comma-separated allowed origins) ───────────
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── AgentQuant (optional) ────────────────────────────
FRED_API_KEY=
MAX_OPTIMIZATION_ITERATIONS=3
DEFAULT_STOCK_SYMBOL=AAPL
DEBUG=False
